-- ============================================================
-- Secure Document Management System (SDMS)
-- SQL Server Database Script
-- ============================================================

-- Step 1: Drop old tables safely
IF OBJECT_ID('AuditLogs', 'U') IS NOT NULL DROP TABLE AuditLogs;
IF OBJECT_ID('Reservations', 'U') IS NOT NULL DROP TABLE Reservations;
IF OBJECT_ID('Documents', 'U') IS NOT NULL DROP TABLE Documents;
IF OBJECT_ID('Sessions', 'U') IS NOT NULL DROP TABLE Sessions;
IF OBJECT_ID('Users', 'U') IS NOT NULL DROP TABLE Users;
GO

-- Step 2: Users table
CREATE TABLE Users (
    userID INT IDENTITY(1,1) PRIMARY KEY,
    fullName VARCHAR(100) NOT NULL,
    emailEncrypted VARCHAR(255) NOT NULL UNIQUE,
    passwordHash VARCHAR(255) NOT NULL,
    isActive BIT NOT NULL DEFAULT 1,
    createdAt DATETIME NOT NULL DEFAULT GETDATE()
);
GO

-- Step 3: Sessions table
CREATE TABLE Sessions (
    sessionID INT IDENTITY(1,1) PRIMARY KEY,
    userID INT NOT NULL,
    createdAt DATETIME NOT NULL DEFAULT GETDATE(),
    expiresAt DATETIME NOT NULL,
    isActive BIT NOT NULL DEFAULT 1,

    FOREIGN KEY (userID) REFERENCES Users(userID),
    CHECK (expiresAt > createdAt)
);
GO

-- Step 4: Documents table
CREATE TABLE Documents (
    documentID INT IDENTITY(1,1) PRIMARY KEY,
    title VARCHAR(255) NOT NULL,
    filePath VARCHAR(255) NOT NULL,
    category VARCHAR(100) NOT NULL,
    encrypted BIT NOT NULL DEFAULT 1,
    uploadedBy INT NOT NULL,
    timestamp DATETIME NOT NULL DEFAULT GETDATE(),

    FOREIGN KEY (uploadedBy) REFERENCES Users(userID)
);
GO

-- Step 5: Reservations table
CREATE TABLE Reservations (
    reservationID INT IDENTITY(1,1) PRIMARY KEY,
    documentID INT NOT NULL,
    userID INT NOT NULL,
    reservedAt DATETIME NOT NULL DEFAULT GETDATE(),
    expiresAt DATETIME NOT NULL,
    status VARCHAR(50) NOT NULL DEFAULT 'Active',

    FOREIGN KEY (documentID) REFERENCES Documents(documentID),
    FOREIGN KEY (userID) REFERENCES Users(userID),

    CHECK (status IN ('Active', 'Expired', 'Released', 'Cancelled')),
    CHECK (expiresAt > reservedAt)
);
GO

-- Step 6: AuditLogs table
CREATE TABLE AuditLogs (
    logID INT IDENTITY(1,1) PRIMARY KEY,
    userID INT NULL,
    action VARCHAR(255) NOT NULL,
    targetID INT NULL,
    timestamp DATETIME NOT NULL DEFAULT GETDATE(),
    outcome VARCHAR(50) NOT NULL,

    FOREIGN KEY (userID) REFERENCES Users(userID),

    CHECK (action IN (
        'REGISTER',
        'LOGIN',
        'LOGOUT',
        'UPLOAD_DOCUMENT',
        'DOWNLOAD_DOCUMENT',
        'SEARCH_DOCUMENTS',
        'VIEW_DOCUMENT',
        'RESERVE_DOCUMENT',
        'RELEASE_RESERVATION',
        'SECURITY_BLOCKED'
    )),

    CHECK (outcome IN ('SUCCESS', 'FAILED', 'BLOCKED'))
);
GO

-- Step 7: Indexes for performance
CREATE INDEX IX_Users_Email ON Users(emailEncrypted);
CREATE INDEX IX_Sessions_User_Active ON Sessions(userID, isActive);
CREATE INDEX IX_Documents_Title_Category ON Documents(title, category);
CREATE INDEX IX_Reservations_Document_Status ON Reservations(documentID, status);
CREATE INDEX IX_AuditLogs_User_Action ON AuditLogs(userID, action);
GO

