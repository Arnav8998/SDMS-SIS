-- Step 14: Release reservation example
UPDATE Reservations
SET status = 'Released'
WHERE reservationID = 1
  AND userID = 1
  AND status = 'Active';
GO

-- Step 15: Logout example
UPDATE Sessions
SET isActive = 0
WHERE sessionID = 1
  AND userID = 1;
